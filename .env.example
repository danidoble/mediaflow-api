# Database
DATABASE_URL=postgresql+asyncpg://mediaflow:mediaflow@db:5432/mediaflow
POSTGRES_USER=mediaflow
POSTGRES_PASSWORD=mediaflow
POSTGRES_DB=mediaflow

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# MinIO (swap MINIO_ENDPOINT for your S3 endpoint to use AWS S3 instead)
MINIO_ENDPOINT=minio:9000
# Public endpoint used in presigned URLs (must be reachable by API clients).
# In dev: host:MINIO_API_PORT. In prod: your CDN/domain. Leave blank to use MINIO_ENDPOINT.
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_PUBLIC_SECURE=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mediaflow
MINIO_SECURE=false
PRESIGNED_URL_EXPIRE=3600

# JWT — generate a strong secret: openssl rand -hex 32
SECRET_KEY=changeme-in-production-use-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Upload limits
MAX_UPLOAD_SIZE_MB=500

# CORS — comma separated or JSON list
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8080","http://localhost:4321","http://mediaflow.test","https://mediaflow.test"]

# Workers (informational — set via docker compose scale)
CELERY_WORKERS=2

# Debug
DEBUG=false

# Exposed ports (host-side — change if you have conflicts)
API_PORT=8000
DB_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
